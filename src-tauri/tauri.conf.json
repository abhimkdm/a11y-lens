{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "A11y Lens",
  "version": "2.0.0",
  "identifier": "com.a11ylens.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "A11y Lens — AI Accessibility Testing",
        "width": 1360,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 700
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["sidecar/a11y-sidecar"]
  }
}
